# Copy to .env and fill values (optional). Export as environment variables before running.
# LinkedIn credentials
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Gemini / Google GenAI key
GEMINI_API_KEY=

# Gmail app password (for Stage 4 email sending)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Candidate defaults (optional)
CANDIDATE_NAME=Your Name
CANDIDATE_FIRST_NAME=Your
CANDIDATE_EMAIL=your-email@example.com
CANDIDATE_BIO_FS=Experienced Software Engineer (Node.js, Python, React)
CANDIDATE_BIO_FE=Experienced Frontend Engineer (React, Next.js, TypeScript)
CANDIDATE_PITCH=I'm a software engineer with 4+ years of experience building scalable web applications and APIs.

# Optional: override config.yaml values via envs (comma-separated lists where appropriate)
POSITIONS=Software Engineer,Full Stack Developer,Frontend Developer
PEOPLE_PROFILES=Recruiter,Talent Acquisition,Hiring
RECRUITER_KEYWORDS=recruiter,talent,hiring
MAX_JOB_PAGE=5
MAX_PEOPLE_PER_PROFILE=3
RECRUITERS_ONLY=true
SEND_INVITE_NOTE=true
CONTACT_HIRER_FIRST=true
AI_SYSTEM_PROMPT=
RESUME_LINK=https://drive.google.com/your_resume_link
RESUME_LINK_FRONTEND=https://drive.google.com/your_resume_link
EMAIL_SUBJECT_TEMPLATE=Referral request: {job_title} at {company}
EMAIL_BODY_TEMPLATE=Hi {name},

I came across the {job_title} opening at {company} and felt my background is a strong match.

Quick context — I'm {candidate_first_name}, a {candidate_bio_long}. Resume: {resume_link}

If the role is still open, I'd be grateful for a referral or any pointer toward the hiring manager.

Thanks!
{candidate_name}
{candidate_email}

# Local resume PDF paths (optional) — prefer absolute paths
RESUME_PATH_FULLSTACK=/path/to/resume_fullstack.pdf
RESUME_PATH_FRONTEND=/path/to/resume_frontend.pdf

# Run headless? true/false
HEADLESS=false

# Convenience: set this to your git remote to use scripts/push_to_github.sh
GIT_REMOTE=git@github.com:youruser/yourrepo.git
